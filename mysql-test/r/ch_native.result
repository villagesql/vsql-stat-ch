# Install the extension.
INSTALL EXTENSION vsql_stat_ch;
# Sysvars registered (defaults).
SHOW VARIABLES LIKE 'vsql_stat_ch.%';
Variable_name	Value
vsql_stat_ch.batch_max	10000
vsql_stat_ch.clickhouse_database	default
vsql_stat_ch.clickhouse_host	localhost
vsql_stat_ch.clickhouse_password	
vsql_stat_ch.clickhouse_port	9000
vsql_stat_ch.clickhouse_table	events_raw
vsql_stat_ch.clickhouse_url	
vsql_stat_ch.clickhouse_user	default
vsql_stat_ch.compression	1
vsql_stat_ch.enabled	OFF
vsql_stat_ch.flush_interval_ms	1000
vsql_stat_ch.http_timeout_secs	10
vsql_stat_ch.queue_capacity	100000
vsql_stat_ch.statement_max_bytes	4096
vsql_stat_ch.transport	native
# Point at a dead host (nothing listening / unroutable port) and enable
# capture with a short flush interval so the worker attempts a delivery
# quickly. The bounded connect makes the failure fast, not a hang.
# Run a query; the POSTEXECUTE hook should capture it.
SELECT 'vsql_stat_probe_marker' AS marker;
marker
vsql_stat_probe_marker
# events_captured advances (capture works, no network needed).
SELECT VARIABLE_VALUE > 0 AS events_captured_positive
FROM performance_schema.global_status
WHERE VARIABLE_NAME = 'vsql_stat_ch.events_captured';
events_captured_positive
1
# The worker ran and attempted delivery to the dead host, so flush_errors
# advances -- proving hook -> queue -> worker -> connect fired.
SELECT VARIABLE_VALUE > 0 AS flush_attempted
FROM performance_schema.global_status
WHERE VARIABLE_NAME = 'vsql_stat_ch.flush_errors';
flush_attempted
1
# Disable and uninstall cleanly.
SET GLOBAL vsql_stat_ch.enabled = OFF;
UNINSTALL EXTENSION vsql_stat_ch;
